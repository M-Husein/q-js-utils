{
  "presets": [
    [
      "@babel/preset-env",
      {
        "targets": {
          "browsers": [
            "last 2 versions",
            "safari >= 7",
            "edge >= 14",
            "not ie <= 10",
            "not op_mini all"
          ]
        },
        "exclude": [
          "@babel/plugin-transform-typeof-symbol",
          "@babel/plugin-transform-parameters"
        ],
        "modules": false
      }
    ],
    "@babel/preset-typescript"
  ]
}
